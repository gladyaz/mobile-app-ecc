# Base URL of the local media server serving company drama videos for dev/testing.
# See README.md "Local Company Video Playback" for setup steps.
EXPO_PUBLIC_MEDIA_BASE_URL=http://YOUR_MAC_LOCAL_IP:8000

# Base URL of the NestJS backend (see README.md "Mobile-to-Backend Setup").
EXPO_PUBLIC_API_BASE_URL=http://YOUR_MAC_IP:3000

# Set to "true" to force the app to use bundled mock data instead of the
# backend, even if EXPO_PUBLIC_API_BASE_URL is set.
EXPO_PUBLIC_USE_MOCK_DATA=false
